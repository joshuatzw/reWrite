{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reWrite",
  "version": "1.0.0",
  "identifier": "com.joshuatan.rewrite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["rewrite"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/joshuatzw/reWrite/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNjI3NUFFQzQzQjQ4MUQKUldRZFNEdkVyblZpSThFcEJkelRFK0pubzRUdzBrQmNOcUhGSGl5QjZwblFYUm5EdE1yUFQ4U3cK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
